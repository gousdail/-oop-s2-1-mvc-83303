@model oop_s2_2_mvc_83303.Models.FollowUp

@{
    ViewData["Title"] = "Delete Follow-up";
}

<h1>Delete Follow-up</h1>

<h3>Are you sure you want to delete this follow-up action?</h3>
<div>
    <h4>Follow-up</h4>
    <hr />
    <dl class="row">
        <dt class = "col-sm-2">Due Date</dt>
        <dd class = "col-sm-10">@Model.DueDate.ToShortDateString()</dd>
        <dt class = "col-sm-2">Status</dt>
        <dd class = "col-sm-10">@Model.Status</dd>
    </dl>
    
    <form asp-action="Delete">
        <input type="hidden" asp-for="Id" />
        <input type="submit" value="Delete" class="btn btn-danger" /> |
        <a asp-controller="Inspections" asp-action="Details" asp-route-id="@Model.InspectionId">Back to Inspection</a>
    </form>
</div>
